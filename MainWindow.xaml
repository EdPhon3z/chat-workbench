<Window x:Class="GPTBackup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Chat Workbench"
        Icon="assets/app-icon.ico"
        Width="1280"
        Height="780"
        MinWidth="920"
        MinHeight="520"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Background="#F5F3EE">
  <Window.Resources>
    <SolidColorBrush x:Key="InkBrush" Color="#17201E" />
    <SolidColorBrush x:Key="MutedBrush" Color="#62706B" />
    <SolidColorBrush x:Key="RailBrush" Color="#EEE9DF" />
    <SolidColorBrush x:Key="LineBrush" Color="#D8D0C1" />
    <SolidColorBrush x:Key="ActionBrush" Color="#1F755F" />
    <SolidColorBrush x:Key="ActionHoverBrush" Color="#195F4E" />
    <SolidColorBrush x:Key="DangerBrush" Color="#A55D51" />

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
    </Style>

    <Style x:Key="HelpIconButton" TargetType="Button">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
      <Setter Property="Margin" Value="4,0,0,0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Content" Value="&#xE897;" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="Background" Value="#F7F3EA" />
      <Setter Property="BorderBrush" Value="#C9BFAF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Help" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="IsTabStop" Value="False" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Width="{TemplateBinding Width}"
                    Height="{TemplateBinding Height}"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="9">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="#FFFFFF" />
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource ActionBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ActionBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="Button">
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="Background" Value="{StaticResource ActionBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource ActionBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="5">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ActionHoverBrush}" />
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource ActionHoverBrush}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                <Setter Property="Cursor" Value="Arrow" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="{StaticResource DangerBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
    </Style>

    <Style x:Key="TabButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Height" Value="30" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="Background" Value="#FBFAF6" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1,1,1,0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6,6,0,0">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="InactiveTabButton" TargetType="Button" BasedOn="{StaticResource TabButton}">
      <Setter Property="Height" Value="26" />
      <Setter Property="Margin" Value="5,4,0,0" />
      <Setter Property="Background" Value="#E5DED1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="7,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="ListBox">
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition x:Name="LeftColumn" Width="320" MinWidth="44" />
      <ColumnDefinition Width="5" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border x:Name="SidePanel"
            Grid.Column="0"
            Background="{StaticResource RailBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="0,0,1,0">
      <Grid>
        <StackPanel x:Name="CollapsedRail"
                    Visibility="Collapsed"
                    Margin="4">
          <Button Content="&gt;"
                  Width="34"
                  ToolTip="Expand panel"
                  Style="{StaticResource SecondaryButton}"
                  Click="ExpandSidePanelButton_Click" />
          <Button Content="B"
                  Width="34"
                  Margin="0,8,0,0"
                  ToolTip="Show backup panel"
                  Style="{StaticResource SecondaryButton}"
                  Click="ShowBackupPanelButton_Click" />
          <Button Content="A"
                  Width="34"
                  Margin="0,6,0,0"
                  ToolTip="Show archive search"
                  Style="{StaticResource SecondaryButton}"
                  Click="ShowArchivePanelButton_Click" />
        </StackPanel>

        <ScrollViewer x:Name="ExpandedPanel"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="6">
          <Grid Margin="0,0,0,1">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="Chat Workbench"
                         FontSize="25"
                         FontWeight="Bold"
                         Foreground="{StaticResource InkBrush}" />
              <Button Style="{StaticResource HelpIconButton}"
                      ToolTip="Sign in with SSO/MFA if needed, then use the backup controls." />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="&lt;"
                    Width="30"
                    Height="26"
                    ToolTip="Collapse panel"
                    Style="{StaticResource SecondaryButton}"
                    Click="CollapseSidePanelButton_Click" />
          </Grid>
          <TextBlock x:Name="StatusText"
                     Text="Opening ChatGPT..."
                     TextWrapping="Wrap"
                     Margin="0,0,0,5"
                     FontSize="11"
                     LineHeight="14"
                     Foreground="{StaticResource MutedBrush}" />

          <UniformGrid Columns="2" Margin="0,0,0,0">
            <Button x:Name="ShowBackupPanelButton"
                    Content="Backup"
                    Margin="0,0,5,0"
                    ToolTip="Show backup controls"
                    Style="{StaticResource TabButton}"
                    Click="ShowBackupPanelButton_Click" />
            <Button x:Name="ShowArchivePanelButton"
                    Content="Archive"
                    Margin="5,0,0,0"
                    ToolTip="Show archive search"
                    Style="{StaticResource InactiveTabButton}"
                    Click="ShowArchivePanelButton_Click" />
          </UniformGrid>

          <Border x:Name="SelectedPanelFrame"
                  Margin="0,0,0,0"
                  Padding="6"
                  Background="#FBFAF6"
                  BorderBrush="{StaticResource LineBrush}"
                  BorderThickness="1"
                  CornerRadius="0,0,6,6">
          <Grid>
          <StackPanel x:Name="BackupPanel">
          <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="74" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="BROWSER" Style="{StaticResource SectionTitle}" />
              <Button Style="{StaticResource HelpIconButton}"
                      ToolTip="Open returns to ChatGPT. Save Current backs up the chat currently shown in the browser." />
            </StackPanel>
            <Button x:Name="OpenChatGptButton"
                    Grid.Column="1"
                    Content="Open"
                    Margin="0,0,5,0"
                    Style="{StaticResource SecondaryButton}"
                    Click="OpenChatGptButton_Click" />
            <Button x:Name="BackupCurrentButton"
                    Grid.Column="2"
                    Content="Save Current"
                    Margin="5,0,0,0"
                    Click="BackupCurrentButton_Click" />
          </Grid>

          <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="74" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="QUEUE" Style="{StaticResource SectionTitle}" />
              <Button Style="{StaticResource HelpIconButton}"
                      ToolTip="Discover scans your ChatGPT sidebar. Backup saves pending discovered chats using the batch and delay settings." />
            </StackPanel>
            <Button x:Name="ScanListButton"
                    Grid.Column="1"
                    Content="Discover"
                    Margin="0,0,5,0"
                    Style="{StaticResource SecondaryButton}"
                    Click="ScanListButton_Click" />
            <Button x:Name="BackupAllButton"
                    Grid.Column="2"
                    Content="Backup"
                    Margin="5,0,0,0"
                    Click="BackupAllButton_Click" />
          </Grid>

          <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="94" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="BackupAllCheckBox"
                      Grid.Column="0"
                      Content="All"
                      Margin="0,0,4,0"
                      VerticalAlignment="Center"
                      IsChecked="False"
                      Checked="BackupAllCheckBox_Changed"
                      Unchecked="BackupAllCheckBox_Changed" />
            <TextBlock Grid.Column="1"
                       Text="Batch"
                       Margin="4,0,5,0"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{StaticResource MutedBrush}"
                       ToolTip="How many pending chats to back up in this run when All is unchecked." />
            <TextBox x:Name="BatchSizeBox"
                     Grid.Column="2"
                     Margin="0,0,6,0"
                     Text="25" />
            <TextBlock Grid.Column="3"
                       Text="Delay"
                       Margin="0,0,5,0"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{StaticResource MutedBrush}"
                       ToolTip="Seconds to wait between opening chats. Higher values reduce rate-limit risk." />
            <TextBox x:Name="DelaySecondsBox"
                     Grid.Column="4"
                     Text="8" />
          </Grid>

          <UniformGrid Columns="2" Margin="0,0,0,5">
            <Button x:Name="PauseButton"
                    Content="Pause"
                    Margin="0,0,5,0"
                    ToolTip="Stop after the current chat finishes."
                    IsEnabled="False"
                    Style="{StaticResource DangerButton}"
                    Click="PauseButton_Click" />
            <Button x:Name="RetryFailedButton"
                    Content="Retry"
                    Margin="5,0,0,0"
                    ToolTip="Move failed chats back to pending and back up another batch."
                    Style="{StaticResource SecondaryButton}"
                    Click="RetryFailedButton_Click" />
          </UniformGrid>

          <StackPanel Orientation="Horizontal">
            <TextBlock Text="STATUS" Style="{StaticResource SectionTitle}" />
            <Button Style="{StaticResource HelpIconButton}"
                    ToolTip="Discovered chats are known. Saved chats are backed up. Pending chats still need backup. Failed chats can be retried." />
          </StackPanel>
          <TextBlock x:Name="StatsText"
                     Text="Discovered: 0 | Saved: 0 | Pending: 0 | Failed: 0"
                     TextWrapping="Wrap"
                     Margin="0,0,0,3"
                     FontSize="12"
                     Foreground="{StaticResource MutedBrush}" />
          </StackPanel>

          <StackPanel x:Name="ArchivePanel" Visibility="Collapsed">
          <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
            <TextBlock Text="ARCHIVE" Style="{StaticResource SectionTitle}" />
            <Button Style="{StaticResource HelpIconButton}"
                    ToolTip="Search saved chat text. Select a result to export the full chat or create a new-chat continuation file." />
          </StackPanel>
          <TextBox x:Name="SearchBox"
                   Margin="0,0,0,5"
                   TextChanged="SearchBox_TextChanged" />
          <DataGrid x:Name="ResultsList"
                    MinHeight="150"
                    Height="230"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    IsReadOnly="True"
                    HeadersVisibility="Column"
                    SelectionMode="Single"
                    SelectionChanged="ResultsList_SelectionChanged"
                    MouseDoubleClick="ResultsList_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Title"
                                  Binding="{Binding Title}"
                                  Width="*" />
              <DataGridTextColumn Header="Msgs"
                                  Binding="{Binding MessageCount}"
                                  Width="48" />
              <DataGridTextColumn Header="Saved"
                                  Binding="{Binding SavedAt}"
                                  Width="92" />
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Refresh From ChatGPT"
                          Click="RefreshSelectedChatMenuItem_Click" />
                <Separator />
                <MenuItem Header="Export Transcript"
                          Click="ExportTranscriptMenuItem_Click" />
                <MenuItem Header="Chat Handoff"
                          Click="ExportContinuationMenuItem_Click" />
              </ContextMenu>
            </DataGrid.ContextMenu>
          </DataGrid>

          <UniformGrid Columns="2" Margin="0,6,0,0">
            <Button x:Name="ExportButton"
                    Content="Export..."
                    Margin="0,0,5,0"
                    ToolTip="Choose how to export the selected saved chat."
                    Style="{StaticResource SecondaryButton}"
                    Click="ExportButton_Click">
              <Button.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="Transcript Markdown"
                            Click="ExportTranscriptMenuItem_Click" />
                  <MenuItem Header="Chat Handoff"
                            Click="ExportContinuationMenuItem_Click" />
                </ContextMenu>
              </Button.ContextMenu>
            </Button>
            <Button x:Name="ContinuationExportButton"
                    Content="Chat Handoff"
                    Margin="5,0,0,0"
                    ToolTip="Create a handoff prompt/transcript file for carrying this chat into a fresh conversation."
                    Click="ContinuationExportButton_Click" />
          </UniformGrid>
          </StackPanel>
          </Grid>
          </Border>
        </StackPanel>
      </ScrollViewer>
      </Grid>
    </Border>

    <GridSplitter x:Name="MainSplitter"
                  Grid.Column="1"
                  Width="5"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Background="{StaticResource LineBrush}"
                  ShowsPreview="True" />

    <Border Grid.Column="2" Background="#FFFFFF">
      <wv2:WebView2 x:Name="Browser" />
    </Border>
  </Grid>
</Window>
